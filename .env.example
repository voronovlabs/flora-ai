# ─── Postgres (flora-api) ────────────────────────────────────────────
# In docker-compose the backend talks to the `postgres` service.
# Locally (outside compose) point this at host.docker.internal:55432.
DB_HOST=postgres
DB_PORT=5432
DB_USER=flower
DB_PASSWORD=flower
DB_NAME=flower

# ─── OpenAI (flora-api /smart) ───────────────────────────────────────
# Leave empty to force /smart into heuristic-only mode (no LLM calls).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── Smart query safety knobs (flora-api) ────────────────────────────
SMART_MAX_ROWS=200
SMART_DEFAULT_LIMIT=50
SMART_REQUEST_TIMEOUT=15

# ─── Yandex Search (flora-agent-api scout) ───────────────────────────
# Required only for the live Scout backend. Keep empty to use the Stub.
YANDEX_SEARCH_API_KEY=
YANDEX_SEARCH_FOLDER_ID=
YANDEX_SEARCH_REGION_ID=213
